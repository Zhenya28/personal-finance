generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IncomeCategory {
  WYPLATA_1
  WYPLATA_2
  INNE
}

enum ExpenseCategory {
  ZAKUPY
  RESTAURACJE
  TRANSPORT
  SUBSCRIPTIONS
  MIESZKANIE
  FUN
  OTHER
}

model Income {
  id          String         @id @default(cuid())
  amount      Float
  category    IncomeCategory
  description String?
  date        DateTime
  createdAt   DateTime       @default(now())

  @@index([date])
  @@index([category, date])
}

model Expense {
  id          String          @id @default(cuid())
  amount      Float
  category    ExpenseCategory
  description String?
  date        DateTime
  createdAt   DateTime        @default(now())

  @@index([date])
  @@index([category, date])
}

enum Currency {
  PLN
  USD
  EUR
  GBP
  CHF
}

model Investment {
  id           String   @id @default(cuid())
  ticker       String   @default("VWCE.DE")
  units        Float
  pricePerUnit Float
  date         DateTime
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([ticker, date])
}

model SavingsAccount {
  id           String               @id @default(cuid())
  name         String
  currency     Currency             @default(PLN)
  balance      Float                @default(0)
  transactions SavingsTransaction[]
  updatedAt    DateTime             @updatedAt
  createdAt    DateTime             @default(now())
}

enum SavingsTransactionType {
  DEPOSIT
  WITHDRAWAL
}

model SavingsTransaction {
  id          String                 @id @default(cuid())
  accountId   String
  account     SavingsAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        SavingsTransactionType
  amount      Float
  description String                 @default("")
  date        DateTime
  createdAt   DateTime               @default(now())

  @@index([accountId])
  @@index([date])
  @@index([accountId, date])
}

model CalculatorMonthlyResult {
  id            String   @id @default(cuid())
  month         String   @unique // YYYY-MM
  hoursP1       Float    @default(0)
  hoursP2       Float    @default(0)
  totalKm       Float    @default(0)
  weekdayOrders Int      @default(0)
  weekendOrders Int      @default(0)
  tips          Float    @default(0)
  payoutPeriod1 Float    @default(0)
  payoutPeriod2 Float    @default(0)
  total         Float    @default(0)
  isFinalized   Boolean  @default(false)
  finalizedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
