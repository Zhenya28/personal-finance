generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IncomeCategory {
  WYPLATA_1
  WYPLATA_2
  INNE
}

enum ExpenseCategory {
  ZAKUPY
  RESTAURACJE
  TRANSPORT
  SUBSCRIPTIONS
  MIESZKANIE
  FUN
  OTHER
}

model Income {
  id          String         @id @default(cuid())
  amount      Float
  category    IncomeCategory
  description String?
  date        DateTime
  createdAt   DateTime       @default(now())
}

model Expense {
  id          String          @id @default(cuid())
  amount      Float
  category    ExpenseCategory
  description String?
  date        DateTime
  createdAt   DateTime        @default(now())
}




enum Currency {
  PLN
  USD
  EUR
  GBP
  CHF
}

model Investment {
  id           String   @id @default(cuid())
  ticker       String   @default("VWCE.DE")
  units        Float
  pricePerUnit Float
  commission   Float    @default(0)
  date         DateTime
  createdAt    DateTime @default(now())
}

model SavingsAccount {
  id        String   @id @default(cuid())
  name      String
  currency  Currency @default(PLN)
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model RecurringExpense {
  id          String          @id @default(cuid())
  amount      Float
  category    ExpenseCategory
  description String?
  dayOfMonth  Int             @default(1)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
}

model CategoryRule {
  id          String          @id @default(cuid())
  pattern     String
  type        String          @default("expense") // "expense" | "income"
  category    String
  createdAt   DateTime        @default(now())

  @@unique([pattern, type])
}

model CalculatorMonthlyResult {
  id            String   @id @default(cuid())
  month         String   @unique // YYYY-MM
  hoursP1       Float    @default(0)
  hoursP2       Float    @default(0)
  totalKm       Float    @default(0)
  weekdayOrders Int      @default(0)
  weekendOrders Int      @default(0)
  tips          Float    @default(0)
  payoutPeriod1 Float    @default(0)
  payoutPeriod2 Float    @default(0)
  total         Float    @default(0)
  isFinalized   Boolean  @default(false)
  finalizedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
