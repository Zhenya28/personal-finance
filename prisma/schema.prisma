generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IncomeCategory {
  BASE
  TIPS
  BONUS
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  SUBSCRIPTIONS
  FUN
  OTHER
}

model Income {
  id          String         @id @default(cuid())
  amount      Float
  category    IncomeCategory
  description String?
  date        DateTime
  createdAt   DateTime       @default(now())
}

model Expense {
  id          String          @id @default(cuid())
  amount      Float
  category    ExpenseCategory
  description String?
  date        DateTime
  createdAt   DateTime        @default(now())
}

model BudgetLimit {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  limitAmount Float
  month       String

  @@unique([category, month])
}

model Investment {
  id           String   @id @default(cuid())
  ticker       String   @default("VWCE.DE")
  units        Float
  pricePerUnit Float
  commission   Float    @default(0)
  date         DateTime
  createdAt    DateTime @default(now())
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  createdAt     DateTime  @default(now())
}

model DailyCheckin {
  id        String   @id @default(cuid())
  date      DateTime @unique
  createdAt DateTime @default(now())
}

model Settings {
  id         String @id @default("default")
  hourlyRate Float  @default(0)
}
