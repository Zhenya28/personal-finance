# --- Database (Supabase Postgres) ---
# Pooled connection string used at runtime
DATABASE_URL=
# Direct connection string used by Prisma Migrate
DIRECT_URL=

# --- Auth ---
# Secret used to sign session JWTs (HS256). Required in production.
AUTH_SECRET=
# Single password that grants access to the dashboard.
# Comparison is constant-time over SHA-256 hashes; rotate by changing this value.
AUTH_PASSWORD=

# --- AI ---
# Google Gemini API key (powers /scan vision + CSV auto-categorization).
# Optional in dev; without it AI features fall back to heuristics/default categories.
GEMINI_API_KEY=
